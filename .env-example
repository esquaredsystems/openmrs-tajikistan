# =============================================================================
# OpenMRS Tajikistan – Docker environment variables
# Copy this file to .env and fill in your values before running docker compose.
# NEVER commit this file to version control with real credentials.
# =============================================================================

# ── OpenMRS application database (MySQL 8) ───────────────────────────────────
# For host OS MySQL, use "host.docker.internal" (Windows/Mac) or your host IP
OPENMRS_DB_HOST=host.docker.internal
OPENMRS_DB_PORT=3306
OPENMRS_DB_NAME=openmrs
OPENMRS_DB_USER=openmrs
OPENMRS_DB_PASSWORD=openmrs

# ── Host port mappings ────────────────────────────────────────────────────────
# OpenMRS Tomcat (http://localhost:<port>/openmrs)
OPENMRS_HOST_PORT=8080
